{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        "TelemetryDbContext": "Host=localhost;Port=5438;Database=telemetry_db;Username=postgres;Password=password"
    },
    "JwtOptions": {
        "SecretKey": "super-secret-key-must-be-at-least-32-characters-long",
        "Issuer": "AquaSmart.Identity",
        "Audience": "AquaSmart.Gateway",
        "ExpiresHours": 12
    },
    "RabbitMqOptions": {
        "Host": "amqp://localhost:5672",
        "UserName": "guest",
        "Password": "guest"
    },
    "TelemetrySettings": {
        "MaxLiveTimeForRawDataInHours": -24,
        "MaxLiveTimeForMinutesDataInDayes": -7,
        "MaxLiveTimeForHourseDataInDayes": -90
    }
}
