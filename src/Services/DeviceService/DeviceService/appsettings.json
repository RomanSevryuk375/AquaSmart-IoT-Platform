{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        "SystemDbContext": "Host=localhost;Port=5439;Database=device_db;Username=postgres;Password=password"
    },
    "JwtOptions": {
        "SecretKey": "super-secret-key-must-be-at-least-32-characters-long",
        "Issuer": "AquaSmart.Identity",
        "Audience": "AquaSmart.Gateway",
        "ExpiresHours": 12
    },
    "RabbitMqOptions": {
        "Host": "amqp://localhost:5672",
        "UserName": "guest",
        "Password": "guest"
    },
    "DeviceSettings": {
        "CommandTtlMinutes": 10,
        "DefaultSendIntervalMs": 10000,
        "MaxConfigBatchSize": 50
    },
    "BackgroundJobs": {
        "OutboxProcessorIntervalSeconds": 1,
        "OfflineCheckerIntervalSeconds": 60,
        "DeleteCompletedCommandsIntervalHours": 3
    },
    "AllowedHosts": "*"
}
